<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact & Rendez-vous – Cabinet Barcelonne & Loison</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--navy:#0f2235;--teal:#2a7d6f;--teal-light:#3aa08e;--cream:#f7f5f0;--white:#ffffff;--gray-light:#f0eeea;--gray-mid:#c8c4bc;--gray-text:#6b6560;--gold:#c9a96e;--font-display:'Cormorant Garamond',serif;--font-body:'DM Sans',sans-serif;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}html{scroll-behavior:smooth;}body{font-family:var(--font-body);background:var(--white);color:var(--navy);line-height:1.6;overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 5vw;height:72px;background:rgba(255,255,255,0.92);backdrop-filter:blur(12px);border-bottom:1px solid rgba(42,125,111,0.12);transition:box-shadow .3s;}nav.scrolled{box-shadow:0 4px 24px rgba(15,34,53,0.08);}
.nav-logo{font-family:var(--font-display);font-size:1.25rem;font-weight:500;color:var(--navy);letter-spacing:0.02em;text-decoration:none;display:flex;flex-direction:column;line-height:1.2;}.nav-logo span{font-size:0.65rem;font-family:var(--font-body);font-weight:300;color:var(--teal);letter-spacing:0.12em;text-transform:uppercase;}
.nav-links{display:flex;gap:2.5rem;list-style:none;}.nav-links a{text-decoration:none;font-size:0.82rem;font-weight:400;color:var(--gray-text);letter-spacing:0.04em;transition:color .2s;}.nav-links a:hover,.nav-links a.active{color:var(--teal);}
.nav-cta{background:var(--teal);color:white;padding:10px 22px;border-radius:2px;font-size:0.8rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;text-decoration:none;transition:background .2s,transform .2s;}.nav-cta:hover{background:var(--teal-light);transform:translateY(-1px);}
.page-hero{padding:140px 8vw 5rem;background:var(--navy);position:relative;overflow:hidden;}.page-hero::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 50%,rgba(42,125,111,0.18) 0%,transparent 70%);pointer-events:none;}
.breadcrumb{display:flex;gap:8px;align-items:center;font-size:0.75rem;color:rgba(255,255,255,0.4);margin-bottom:2rem;position:relative;z-index:1;}.breadcrumb a{color:rgba(255,255,255,0.4);text-decoration:none;}.breadcrumb span{color:rgba(255,255,255,0.7);}
.page-hero-label{font-size:0.72rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--teal-light);font-weight:500;margin-bottom:1rem;display:flex;align-items:center;gap:10px;position:relative;z-index:1;}.page-hero-label::before{content:'';display:block;width:20px;height:1px;background:var(--teal-light);}
.page-hero-title{font-family:var(--font-display);font-size:clamp(2.5rem,4vw,4.5rem);font-weight:300;color:white;line-height:1.1;margin-bottom:1.25rem;position:relative;z-index:1;}.page-hero-title em{font-style:italic;color:var(--teal-light);}
.page-hero-sub{font-size:0.95rem;color:rgba(255,255,255,0.6);max-width:560px;line-height:1.75;position:relative;z-index:1;}
section{padding:5rem 8vw;}
.section-label{font-size:0.72rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--teal);font-weight:500;margin-bottom:1rem;display:flex;align-items:center;gap:10px;}.section-label::before{content:'';display:block;width:20px;height:1px;background:var(--teal);}
.section-title{font-family:var(--font-display);font-size:clamp(2rem,3vw,3rem);font-weight:300;line-height:1.15;color:var(--navy);margin-bottom:1rem;}.section-title em{font-style:italic;color:var(--teal);}

/* CONTACT MAIN */
.contact-main{background:var(--white);}
.contact-layout{display:grid;grid-template-columns:1fr 1.3fr;gap:5rem;margin-top:3rem;}

/* INFO SIDE */
.info-blocks{display:flex;flex-direction:column;gap:2.5rem;}
.info-block{display:flex;gap:1.25rem;align-items:flex-start;}
.info-icon{width:48px;height:48px;background:rgba(42,125,111,0.08);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid rgba(42,125,111,0.15);}
.info-icon svg{width:20px;height:20px;color:var(--teal);}
.info-label{font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--teal);font-weight:500;margin-bottom:5px;}
.info-value{font-size:0.9rem;color:var(--navy);line-height:1.6;}
.info-value a{color:var(--teal);text-decoration:none;font-weight:500;}
.info-value a:hover{text-decoration:underline;}

/* HORAIRES */
#horaires{background:var(--cream);}
.horaires-layout{display:grid;grid-template-columns:1fr 1fr;gap:4rem;margin-top:3rem;align-items:start;}
.horaires-table{width:100%;border-collapse:collapse;}
.horaires-table tr{border-bottom:1px solid rgba(0,0,0,0.06);}
.horaires-table tr:last-child{border-bottom:none;}
.horaires-table td{padding:12px 0;font-size:0.88rem;}
.horaires-table td:first-child{color:var(--gray-text);width:130px;}
.horaires-table td:last-child{color:var(--navy);font-weight:500;text-align:right;}
.horaires-table td.closed{color:var(--gray-mid) !important;font-weight:300;}
.today-row td{color:var(--teal) !important;font-weight:600 !important;}
.today-row td:last-child{color:var(--teal) !important;}
.horaires-note{background:white;border:1px solid var(--gray-light);border-radius:2px;padding:1.5rem;margin-top:1.5rem;}
.horaires-note-title{font-size:0.82rem;font-weight:600;color:var(--navy);margin-bottom:0.5rem;}
.horaires-note-text{font-size:0.8rem;color:var(--gray-text);line-height:1.65;}
.access-info{display:flex;flex-direction:column;gap:1.25rem;}
.access-item{display:flex;gap:1rem;align-items:flex-start;}
.access-icon{width:36px;height:36px;background:rgba(42,125,111,0.08);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.access-icon svg{width:16px;height:16px;color:var(--teal);}
.access-text-title{font-size:0.78rem;font-weight:600;color:var(--navy);margin-bottom:2px;}
.access-text-sub{font-size:0.78rem;color:var(--gray-text);line-height:1.5;}

/* MAP */
.map-section{background:var(--navy);padding:0;}
.map-container{width:100%;height:400px;position:relative;overflow:hidden;}
.map-container iframe{width:100%;height:100%;border:none;filter:grayscale(20%) contrast(1.05);}
.map-overlay-card{position:absolute;top:2rem;left:8vw;background:white;border-radius:2px;padding:1.5rem 2rem;box-shadow:0 16px 48px rgba(0,0,0,0.2);max-width:280px;z-index:10;}
.map-card-title{font-family:var(--font-display);font-size:1.1rem;color:var(--navy);font-weight:400;margin-bottom:0.25rem;}
.map-card-addr{font-size:0.8rem;color:var(--gray-text);margin-bottom:1rem;line-height:1.5;}
.map-card-link{display:inline-flex;align-items:center;gap:6px;font-size:0.75rem;color:var(--teal);font-weight:500;text-decoration:none;letter-spacing:0.06em;text-transform:uppercase;}
.map-card-link:hover{text-decoration:underline;}

/* FORM */
.form-section{background:var(--white);}
.form-container{max-width:700px;margin:3rem auto 0;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-group.full{grid-column:1/-1;}
.form-label{font-size:0.75rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--gray-text);font-weight:500;}
.form-input,.form-select,.form-textarea{padding:13px 16px;border:1px solid var(--gray-light);border-radius:2px;font-family:var(--font-body);font-size:0.88rem;color:var(--navy);background:var(--cream);transition:border-color .2s,box-shadow .2s;outline:none;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(42,125,111,0.1);background:white;}
.form-textarea{resize:vertical;min-height:120px;}
.form-actions{display:flex;align-items:center;gap:2rem;flex-wrap:wrap;margin-top:0.5rem;}
.form-submit{background:var(--teal);color:white;border:none;cursor:pointer;padding:16px 40px;border-radius:2px;font-family:var(--font-body);font-size:0.82rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;transition:background .2s,transform .2s,box-shadow .2s;box-shadow:0 4px 20px rgba(42,125,111,0.25);}
.form-submit:hover{background:var(--teal-light);transform:translateY(-2px);box-shadow:0 8px 28px rgba(42,125,111,0.35);}
.form-submit:disabled{background:var(--gray-mid);cursor:default;transform:none;box-shadow:none;}
.form-note{font-size:0.72rem;color:var(--gray-text);line-height:1.5;}
.form-success{display:none;background:rgba(42,125,111,0.08);border:1px solid rgba(42,125,111,0.2);border-radius:2px;padding:1.5rem;text-align:center;}
.form-success-icon{font-size:2rem;margin-bottom:0.5rem;}
.form-success-title{font-family:var(--font-display);font-size:1.4rem;color:var(--teal);margin-bottom:0.5rem;}
.form-success-text{font-size:0.85rem;color:var(--gray-text);}

footer{background:var(--navy);color:rgba(255,255,255,0.5);padding:3rem 8vw 2rem;}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem;}
.footer-logo{font-family:var(--font-display);font-size:1.1rem;color:white;font-weight:400;margin-bottom:0.75rem;}.footer-tagline{font-size:0.8rem;line-height:1.65;max-width:260px;}
.footer-col-title{font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.7);font-weight:500;margin-bottom:1rem;}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:0.6rem;}.footer-links a{color:rgba(255,255,255,0.5);text-decoration:none;font-size:0.82rem;transition:color .2s;}.footer-links a:hover{color:var(--teal-light);}
.footer-bottom{border-top:1px solid rgba(255,255,255,0.08);padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;font-size:0.75rem;}.footer-bottom a{color:rgba(255,255,255,0.4);text-decoration:none;}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease;}.reveal.visible{opacity:1;transform:translateY(0);}
@media(max-width:900px){.contact-layout{grid-template-columns:1fr;gap:3rem;}.horaires-layout{grid-template-columns:1fr;}.form-grid{grid-template-columns:1fr;}.form-group.full{grid-column:1;}.footer-grid{grid-template-columns:1fr 1fr;gap:2rem;}section{padding:3.5rem 5vw;}.page-hero{padding:120px 5vw 3.5rem;}.map-overlay-card{position:static;margin:2rem;max-width:100%;}}
</style>
</head>
